<!DOCTYPE html>
<html xmlns:th="http://www.thymeleaf.org">
<head>
    <title>Cloud App - Characters</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
	<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
</head>

<body class="container mt-5">

	<div class="d-flex justify-content-between align-items-center mb-3">
	    <h1 class="mb-0">Characters</h1>
	    <div class="d-flex gap-2">
	        <a class="btn btn-secondary" th:href="@{/}">Home</a>
	        <a class="btn btn-primary" th:href="@{/characters/create}">Create Character</a>
	    </div>
	</div>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th>Name</th>
            <th>Race</th>
            <th>Class</th>
            <th>Level</th>
            <th>Type</th>
            <th>Gender</th>
			<th>Actions</th>
        </tr>
    </thead>
    <tbody>
        <tr th:each="c : ${characters}">
            <td th:text="${c.characterName}"></td>
            <td th:text="${c.characterRace}"></td>
            <td th:text="${c.characterClass}"></td>
            <td th:text="${c.characterLevel}"></td>
            <td th:text="${c.characterType}"></td>
            <td th:text="${c.characterGender}"></td>
			<td class="text-nowrap">

			    <a class="btn btn-sm btn-outline-warning"
				   title="Edit Character"
			       th:href="@{/characters/edit/{id}(id=${c.id})}">
			        <i class="bi bi-pencil-fill"></i>
			    </a>

			    <a class="btn btn-sm btn-outline-danger ms-2"
				   title="Delete Character"
			       th:href="@{/characters/delete/{id}(id=${c.id})}"
			       onclick="return confirm('Delete this character?');">
			        <i class="bi bi-trash-fill"></i>
			    </a>

			</td>
        </tr>
    </tbody>
</table>

</body>
</html>