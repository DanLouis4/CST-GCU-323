package com.gcu.controllers;

import java.util.ArrayList;
import java.util.List;

import org.springframework.stereotype.Controller;
import org.springframework.ui.Model;
import org.springframework.web.bind.annotation.GetMapping;

import com.gcu.models.CharacterModel;

@Controller
public class CharactersController
{
    @GetMapping("/characters")
    public String characters(Model model)
    {
        // Temporary in-memory list (replace with DB later)
        List<CharacterModel> characters = new ArrayList<>();

        characters.add(new CharacterModel("Arthas", "Human", "Knight", 5, "Player", "Male"));
        characters.add(new CharacterModel("Lyra", "Elf", "Ranger", 4, "Player", "Female"));
        characters.add(new CharacterModel("Thorgar", "Dwarf", "Warrior", 6, "NPC", "Male"));
        characters.add(new CharacterModel("Mira", "Human", "Wizard", 3, "Player", "Female"));

        model.addAttribute("characters", characters);

        return "characters";
    }
}